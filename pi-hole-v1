services:
  pihole:
    container_name: pihole
    image: pihole/pihole:latest
    network_mode: host
    restart: unless-stopped
    cap_add:
      - NET_ADMIN
    environment:
      - TZ=America/New_York
      - FTLCONF_webserver_api_password=password_here
      - FTLCONF_dns_listeningMode=all
      # MATCHING PORT: This now matches your .conf file (5335)
      - FTLCONF_dns_upstreams=127.0.0.1#5335
    volumes:
      - '/home/justjt7704/pi-dns/pihole/config:/etc/pihole'
      - '/home/justjt7704/pi-dns/pihole/dnsmasq.d:/etc/dnsmasq.d'

  unbound:
    container_name: unbound
    image: mvance/unbound:latest
    network_mode: host
    restart: unless-stopped
    volumes:
      # Ensure your .conf file is inside a folder named 'unbound'
      # in the same directory as this docker-compose file.
      - '/home/justjt7704/pi-dns/unbound:/opt/unbound/etc/unbound'
